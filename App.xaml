<Application x:Class="Klik.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Klik.Converters"
             ThemeMode="System"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Default theme for design-time / early loading -->
                <ResourceDictionary Source="pack://application:,,,/Themes/DarkTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:BooleanToVisibilityConverter x:Key="BoolToVis" />
            <conv:InverseBooleanConverter x:Key="InverseBool" />

