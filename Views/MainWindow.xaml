<Window x:Class="Klik.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Klik"
        Icon="/klik.ico"
        Width="750" Height="510"
        Topmost="{Binding IsAlwaysOnTop, Mode=TwoWay}"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource WindowForeground}"
        FontFamily="Segoe UI, Microsoft YaHei, Arial"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Grid Margin="16" Background="Transparent" Focusable="True" FocusVisualStyle="{x:Null}" MouseLeftButtonDown="Grid_MouseLeftButtonDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 0 Title -->
            <RowDefinition Height="*" />     <!-- 1 Dashboard Content -->
            <RowDefinition Height="Auto" />  <!-- 2 Status Bar -->
        </Grid.RowDefinitions>

        <!-- Title / Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Path Data="{StaticResource KlikLogoGeometry}" Fill="{DynamicResource AccentBackground}" Width="26" Height="26" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Klik" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="Never 'Hello' a developer" FontSize="11" Opacity="0.55" Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
            </StackPanel>
            <ToggleButton Grid.Column="1" Width="30" Height="30" VerticalAlignment="Center"
                          IsChecked="{Binding IsAlwaysOnTop, Mode=TwoWay}"
                          ToolTip="Always on Top">
                <ToggleButton.Template>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border"
                                Background="{DynamicResource ControlBackground}"
                                BorderBrush="{DynamicResource ControlBorder}"
                                BorderThickness="1"
                                CornerRadius="6"
                                SnapsToDevicePixels="true">
                            <Path x:Name="path" Data="{StaticResource PinIconGeometry}" Fill="{DynamicResource TextSecondary}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="true">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentBackground}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBorder}" />
                                <Setter TargetName="path" Property="Fill" Value="{DynamicResource AccentForeground}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ControlHoverBackground}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ControlHoverBorder}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="true" />
                                    <Condition Property="IsChecked" Value="true" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentHoverBackground}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentHoverBorder}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </ToggleButton.Template>
            </ToggleButton>
        </Grid>

        <!-- Main Dashboard Content -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="20" /> <!-- Spacer -->
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- Left Side: Message & Presets -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Preset dropdown -->
                    <RowDefinition Height="*" />    <!-- Message text box -->
                    <RowDefinition Height="Auto" /> <!-- Start/Stop Buttons -->
                </Grid.RowDefinitions>

                <!-- Preset Selection -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Preset" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Grid Grid.Column="1">
                        <ComboBox ItemsSource="{Binding Presets}" 
                                  SelectedItem="{Binding SelectedPreset, Mode=TwoWay}" 
                                  Height="30" 
                                  Padding="10,0,28,0"
                                  VerticalContentAlignment="Center"
                                  x:Name="PresetCombo"
                                  MaxDropDownHeight="200"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  VirtualizingStackPanel.IsVirtualizing="True"
                                  VirtualizingStackPanel.VirtualizationMode="Recycling">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="MaxWidth" Value="{Binding ActualWidth, ElementName=PresetCombo}" />
                                </Style>
                            </ComboBox.ItemContainerStyle>
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" 
                                               TextTrimming="CharacterEllipsis" 
                                               ToolTip="{Binding Name}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,24,0" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock IsHitTestVisible="False" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{DynamicResource TextMuted}" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Select a preset..." />
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding SelectedPreset}" Value="{x:Null}" />
                                                <Condition Binding="{Binding HasPresets}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding SelectedPreset}" Value="{x:Null}" />
                                                <Condition Binding="{Binding HasPresets}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Text" Value="No presets. Click ⚙ to create!" />
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <Button Grid.Column="2" Width="30" Height="30" Margin="6,0,0,0" Command="{Binding OpenPresetsCommand}" ToolTip="Manage presets" Padding="0">
                        <Path Data="{StaticResource GearIconGeometry}" Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Width="14" Height="14" Stretch="Uniform"/>
                    </Button>
                </Grid>

                <!-- Message Box -->
                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <TextBlock Text="Message" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Left" />
                        <TextBlock Text="{Binding CharCountText}" FontSize="11" Opacity="0.6" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Right" />
                    </Grid>
                    <TextBox Grid.Row="1" MinHeight="110" Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
                    <TextBlock Grid.Row="2" Text="{Binding ErrorText}" Foreground="{DynamicResource ErrorForeground}" FontSize="11" Margin="0,4,0,0" Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}" />
                </Grid>

                <!-- Action Buttons -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Height="36" Margin="0,0,6,0" Style="{StaticResource AccentButtonStyle}" Command="{Binding StartCommand}" IsEnabled="{Binding IsIdle}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource PlayIconGeometry}" Fill="White" Width="10" Height="10" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Start (F6)" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1" Height="36" Margin="6,0,0,0" Command="{Binding StopCommand}" IsEnabled="{Binding IsRunning}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource StopIconGeometry}" Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Width="10" Height="10" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Stop (F6)" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>

            <!-- Right Side: Settings Panel -->
            <StackPanel Grid.Column="2">
                <!-- Card 1: Typing Interval -->
                <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Path Data="{StaticResource ClockIconGeometry}" Fill="{DynamicResource AccentBackground}" Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Typing Interval" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                <TextBox Text="{Binding IntervalMinutes, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="NumericOnly_PreviewTextInput" DataObject.Pasting="NumericOnly_Pasting" MaxLength="6" TextAlignment="Center" FontSize="13" Padding="4" Height="28"/>
                                <TextBlock Text="min" FontSize="11" Opacity="0.5" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0,4,0">
                                <TextBox Text="{Binding IntervalSeconds, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="NumericOnly_PreviewTextInput" DataObject.Pasting="NumericOnly_Pasting" MaxLength="6" TextAlignment="Center" FontSize="13" Padding="4" Height="28"/>
                                <TextBlock Text="sec" FontSize="11" Opacity="0.5" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="4,0,0,0">
                                <TextBox Text="{Binding IntervalMilliseconds, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="NumericOnly_PreviewTextInput" DataObject.Pasting="NumericOnly_Pasting" MaxLength="6" TextAlignment="Center" FontSize="13" Padding="4" Height="28"/>
                                <TextBlock Text="ms" FontSize="11" Opacity="0.5" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Card 2: Send Key -->
                <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <Path Data="{StaticResource KeyboardIconGeometry}" Fill="{DynamicResource AccentBackground}" Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Send Key" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock FontSize="10" Foreground="{DynamicResource TextMuted}" Text="CURRENT KEY"/>
                                <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Text="{Binding SendKeyName}"/>
                            </StackPanel>

                            <Button Grid.Column="1" Command="{Binding BeginKeyRecordingCommand}" Height="30" VerticalAlignment="Center" Width="110" Padding="0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Path Data="{StaticResource TargetIconGeometry}" Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Record Key" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRecordingKey}" Value="True">
                                                <Setter Property="Background" Value="#FFB900" />
                                                <Setter Property="Foreground" Value="#1A1A1A" />
                                                <Setter Property="BorderBrush" Value="#D29900" />
                                                <Setter Property="Content">
                                                    <Setter.Value>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <Path Data="{StaticResource KeyboardIconGeometry}" Fill="#1A1A1A" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                            <TextBlock Text="Press key..." FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Card 3: Stop Condition -->
                <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="8" Padding="12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Path Data="{StaticResource InfoIconGeometry}" Fill="{DynamicResource AccentBackground}" Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Stop Condition" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel>
                            <RadioButton GroupName="stop" Content="Run until manually stopped" Foreground="{DynamicResource TextPrimary}" Margin="0,4,0,4" IsChecked="{Binding StopOnDuration, Converter={StaticResource InverseBool}}" />
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <RadioButton GroupName="stop" Content="Stop automatically after" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" IsChecked="{Binding StopOnDuration}" />
                                <TextBox Width="42" Height="24" Margin="6,0,6,0" Padding="2" TextAlignment="Center" Text="{Binding StopAfterMinutes, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="NumericOnly_PreviewTextInput" DataObject.Pasting="NumericOnly_Pasting" MaxLength="6" />
                                <TextBlock Text="min" VerticalAlignment="Center" Opacity="0.5" Foreground="{DynamicResource TextSecondary}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Bottom Warning Banner & Status Bar -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Warning Banner -->
            <Border Grid.Row="0" Background="{DynamicResource WarningBackground}" BorderBrush="{DynamicResource WarningBorder}" BorderThickness="1" CornerRadius="6" Padding="10,6" VerticalAlignment="Bottom" Margin="0,0,0,10" Visibility="{Binding HasWarning, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource InfoIconGeometry}" Fill="{DynamicResource WarningForeground}" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding WarningText}" Foreground="{DynamicResource WarningForeground}" FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Status Bar -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{Binding StatusColor}" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding StatusText}" FontSize="11" Opacity="0.7" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="{StaticResource SendIconGeometry}" Fill="{DynamicResource TextSecondary}" Width="11" Height="11" Stretch="Uniform" Opacity="0.7" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock FontSize="11" Opacity="0.7" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center">
                        <Run Text="Sent: " /><Run Text="{Binding SendCount}" /><Run Text=" times" />
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Path Data="{StaticResource ClockIconGeometry}" Fill="{DynamicResource TextSecondary}" Width="11" Height="11" Stretch="Uniform" Opacity="0.7" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ElapsedTime}" FontSize="11" Opacity="0.7" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
