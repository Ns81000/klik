<Window x:Class="Klik.Views.PresetsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Klik — Manage Presets"
        Icon="/klik.ico"
        Width="620" Height="390"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource WindowForeground}"
        FontFamily="Segoe UI, Microsoft YaHei, Arial"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Grid Margin="16" Background="Transparent" Focusable="True" FocusVisualStyle="{x:Null}" MouseLeftButtonDown="Grid_MouseLeftButtonDown">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="20" /> <!-- Spacer -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Column: Presets List -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" Text="Saved Presets" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
            
            <ListView Grid.Row="1" ItemsSource="{Binding Presets}"
                      SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                      Background="{DynamicResource InputBackground}"
                      BorderBrush="{DynamicResource InputBorder}"
                      Foreground="{DynamicResource InputForeground}"
                      BorderThickness="1"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" 
                                   TextTrimming="CharacterEllipsis" 
                                   ToolTip="{Binding Name}"
                                   FontSize="12" />
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="8,6" />
                        <Setter Property="Margin" Value="0,1" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
            
            <!-- Empty State -->
            <TextBlock Grid.Row="1" Text="No presets saved.&#x0a;Enter a title and message on the right to create one."
                       Foreground="{DynamicResource TextMuted}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"
                       Margin="16"
                       IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasNoPresets}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- Right Column: Editor Form -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Title Label -->
                <RowDefinition Height="Auto" /> <!-- Title Textbox -->
                <RowDefinition Height="Auto" /> <!-- Message Label -->
                <RowDefinition Height="*" />    <!-- Message Textbox -->
                <RowDefinition Height="Auto" /> <!-- Actions Panel -->
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0" Text="Preset Title" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6" />
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <TextBox Text="{Binding EditingTitle, UpdateSourceTrigger=PropertyChanged}"
                         Height="30"
                         VerticalContentAlignment="Center"
                         x:Name="PresetNameBox" />
                <TextBlock Text="e.g. Greeting Preset..."
                           Foreground="{DynamicResource TextMuted}"
                           IsHitTestVisible="False"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           FontSize="12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=PresetNameBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <!-- Message Text -->
            <TextBlock Grid.Row="2" Text="Preset Message" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6" />
            <TextBox Grid.Row="3" 
                     Text="{Binding EditingText, UpdateSourceTrigger=PropertyChanged}" 
                     TextWrapping="Wrap" 
                     AcceptsReturn="True" 
                     VerticalScrollBarVisibility="Auto" 
                     Margin="0,0,0,16" 
                     VerticalContentAlignment="Top"
                     Padding="8,6"
                     x:Name="PresetMessageBox"/>
            <TextBlock Grid.Row="3" Text="Type the message to send..."
                       Foreground="{DynamicResource TextMuted}"
                       IsHitTestVisible="False"
                       VerticalAlignment="Top"
                       Margin="10,8,0,0"
                       FontSize="12">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=PresetMessageBox}" Value="">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Action Buttons -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <!-- Left Buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Command="{Binding NewPresetCommand}" Width="80" Height="32" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource PlusIconGeometry}" Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Width="10" Height="10" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="New" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding DeletePresetCommand}" Width="90" Height="32">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource TrashIconGeometry}" Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Width="10" Height="10" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Delete" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Right Save Button -->
                <Button Grid.Column="2" Command="{Binding SavePresetCommand}" Width="100" Height="32" Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource CheckIconGeometry}" Fill="White" Width="10" Height="10" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Save" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Window>
