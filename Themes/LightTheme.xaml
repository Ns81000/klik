<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Window & Layout -->
    <SolidColorBrush x:Key="WindowBackground" Color="#f3f3f3" />
    <SolidColorBrush x:Key="WindowForeground" Color="#1a1a1a" />
    <SolidColorBrush x:Key="CardBackground" Color="#ffffff" />
    <SolidColorBrush x:Key="CardBorder" Color="#e5e5e5" />
    
    <!-- Typography -->
    <SolidColorBrush x:Key="TextPrimary" Color="#1a1a1a" />
    <SolidColorBrush x:Key="TextSecondary" Color="#5d5d5d" />
    <SolidColorBrush x:Key="TextMuted" Color="#8a8a8a" />
    
    <!-- Controls (Buttons) -->
    <SolidColorBrush x:Key="ControlBackground" Color="#ffffff" />
    <SolidColorBrush x:Key="ControlForeground" Color="#1a1a1a" />
    <SolidColorBrush x:Key="ControlBorder" Color="#cccccc" />
    <SolidColorBrush x:Key="ControlHoverBackground" Color="#f0f0f0" />
    <SolidColorBrush x:Key="ControlHoverBorder" Color="#b8b8b8" />
    <SolidColorBrush x:Key="ControlPressedBackground" Color="#e0e0e0" />
    <SolidColorBrush x:Key="ControlPressedBorder" Color="#a6a6a6" />
    <SolidColorBrush x:Key="ControlDisabledBackground" Color="#f5f5f5" />
    <SolidColorBrush x:Key="ControlDisabledBorder" Color="#e0e0e0" />
    <SolidColorBrush x:Key="ControlDisabledForeground" Color="#8a8a8a" />

    <!-- Accent Buttons / UI -->
    <SolidColorBrush x:Key="AccentBackground" Color="#0078d4" />
    <SolidColorBrush x:Key="AccentForeground" Color="#ffffff" />
    <SolidColorBrush x:Key="AccentBorder" Color="#006ec4" />
    <SolidColorBrush x:Key="AccentHoverBackground" Color="#1085e0" />
    <SolidColorBrush x:Key="AccentHoverBorder" Color="#0078d4" />
    <SolidColorBrush x:Key="AccentPressedBackground" Color="#006cc0" />
    <SolidColorBrush x:Key="AccentDisabledBackground" Color="#b3d6f2" />
    <SolidColorBrush x:Key="AccentDisabledBorder" Color="#b3d6f2" />
    <SolidColorBrush x:Key="AccentDisabledForeground" Color="#ffffff" />

    <!-- Inputs (TextBox, ComboBox, ListView) -->
    <SolidColorBrush x:Key="InputBackground" Color="#ffffff" />
    <SolidColorBrush x:Key="InputForeground" Color="#1a1a1a" />
    <SolidColorBrush x:Key="InputBorder" Color="#cccccc" />
    <SolidColorBrush x:Key="InputHoverBorder" Color="#b8b8b8" />
    <SolidColorBrush x:Key="InputFocusedBorder" Color="#0078d4" />
    
    <!-- Warnings & Errors -->
    <SolidColorBrush x:Key="ErrorForeground" Color="#c42b1c" />
    <SolidColorBrush x:Key="WarningBackground" Color="#fff4ce" />
    <SolidColorBrush x:Key="WarningBorder" Color="#fde7aa" />
    <SolidColorBrush x:Key="WarningForeground" Color="#7a5500" />
</ResourceDictionary>
